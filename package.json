{
  "name": "brickscope",
  "version": "0.1.0",
  "description": "CLI and MCP server for LEGO recognition — identify parts, sets, and minifigures from images",
  "type": "module",
  "main": "dist/mcp/index.js",
  "bin": {
    "brickscope": "dist/cli/index.js"
  },
  "files": [
    "dist/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "start:mcp": "node dist/mcp/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "lego",
    "brickscope",
    "brickognize",
    "image-recognition",
    "cli",
    "brick",
    "rebrickable"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^9.6.0",
    "commander": "^14.0.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
